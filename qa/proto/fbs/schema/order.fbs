
namespace proto;

table Order {
    symbol     : string(required);
    exchange   : string(required);
    timestamp  : long;
    orderid    : string;

    type       : string;
    direction  : string;
    offset     : string;
    price      : float;
    volume     : float;
    traded     : string;
    status     : string;
    reference  : string;
}

root_type Order;