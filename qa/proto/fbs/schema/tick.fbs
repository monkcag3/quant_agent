
namespace proto;

table Tick {
    symbol     : string(required);
    exchange   : string(required);
    timestamp  : long;

    last_price : float;
    volume     : int;
    amount     : float;

    open_price : float;
    high_price : float;
    low_price  : float;
    close_price: float;

    bid_price  : [float];
    bid_volume : [int];
    ask_price  : [float];
    ask_volume : [int];
}

root_type Tick;